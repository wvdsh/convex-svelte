{
	"name": "@mmailaender/convex-svelte",
	"author": "Convex, Inc. <no-reply@convex.dev>",
	"contributors": [
		"Convex, Inc. <no-reply@convex.dev>",
		"Micha Mailaender"
	],
	"version": "0.13.0",
	"license": "Apache-2.0",
	"homepage": "https://github.com/mmailaender/convex-svelte",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mmailaender/convex-svelte.git"
	},
	"scripts": {
    "dev": "concurrently --kill-others --prefix-colors blue,yellow --names 'svelte,convex' 'pnpm dev:client' 'pnpm dev:server'",
		"dev:client": "vite dev --open",
		"dev:server": "convex dev",
		"dev:init": "convex dev --until-success --run messages:seed",
		"build": "vite build && pnpm package",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && publint",
		"prepublishOnly": "pnpm package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "pnpm test:unit -- --run && pnpm test:e2e",
		"test:e2e": "playwright test"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"convex": ">1.10.0",
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.54.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/eslint": "^9.6.1",
		"@types/node": "^22.19.13",
		"concurrently": "^9.2.1",
		"convex": "^1.32.0",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"publint": "^0.3.18",
		"svelte": "^5.53.6",
		"svelte-check": "^4.4.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"esm-env": "^1.2.2",
		"runed": "^0.37.1"
	}
}
